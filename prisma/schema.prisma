generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Run {
  id           String      @id @default(uuid())
  character    String
  result       String
  ascension    Int?
  actReached   Int?
  floorReached Int?
  notes        String?
  createdAt    DateTime    @default(now())
  seed         String?
  gameMode     String?
  buildId      String?
  killedBy     String?
  runTime      Int?
  offers       CardOffer[]
}

model Card {
  id        String      @id
  name      String
  character String?
  rarity    String
  type      String
  cost      Int?
  isXCost   Boolean     @default(false)
  keywords  String[]
  imageUrl  String?
  offers    CardOffer[]
}

model CardOffer {
  id        String   @id @default(uuid())
  runId     String
  cardId    String
  act       Int?
  floor     Int?
  source    String
  picked    Boolean  @default(false)
  createdAt DateTime @default(now())
  preHp     Int?
  preMaxHp  Int?
  preDamage Int?
  preGold   Int?
  run       Run      @relation(fields: [runId], references: [id])
  card      Card     @relation(fields: [cardId], references: [id])
}

model SpirebirdStat {
  id           String  @id @default(uuid())
  cardId       String
  character    String
  upgraded     Boolean
  cohort       String
  elo          Float?
  eloBT        Float?
  offered      Int
  picked       Int
  pickRate     Float
  wins         Int
  winRate      Float?
  war          Float?
  warA1        Float?
  warA2        Float?
  warA3        Float?
  cWar         Float?
  floorScaling Float?
  warDelta     Float?
  pHP          Float?
  pDMG         Float?

  @@index([cardId, cohort])
}